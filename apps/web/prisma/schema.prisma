generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Identity / buyer
// ---------------------------------------------------------------------------

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  role       Role     @default(BUYER)
  lineUserId String?  @unique
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orchards Orchard[]
  orders   Order[]
  reviews  Review[]
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

// LINE user who has passed phone OTP verification. Gate for order creation.
model VerifiedLineUser {
  id         String   @id @default(uuid())
  lineUserId String   @unique
  phone      String
  name       String?
  consent    Boolean  @default(false)
  verifiedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// OTP issuance/verification log. `reference` is the echo token returned to the client.
model OtpLog {
  reference  String    @id
  phone      String
  otp        String
  lineUserId String?
  expiresAt  DateTime
  consumedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone])
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Orchard {
  id          String   @id @default(uuid())
  name        String
  description String?
  province    String
  ownerId     String
  isVerified  Boolean  @default(false)
  rating      Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User  @relation(fields: [ownerId], references: [id])
  lots  Lot[]

  scopes UserOrchardScope[]

  registerCodes OrchardRegisterCode[]
  lineBindings  OrchardLineBinding[]

  reviews Review[]
}

model Lot {
  id              String    @id @default(uuid())
  orchardId       String
  fruitName       String
  variety         String?
  grade           String?
  price           Decimal
  quantity        Int
  unit            String    @default("kg")
  minOrderQty     Int?
  harvestDate     DateTime?
  saleWindowStart DateTime?
  saleWindowEnd   DateTime?
  status          LotStatus @default(DRAFT)
  qcStatus        QcStatus  @default(PENDING)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orchard    Orchard     @relation(fields: [orchardId], references: [id])
  orderItems OrderItem[]
  qcAudits   QcAudit[]
}

enum LotStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  CANCELLED
}

enum QcStatus {
  PENDING
  RELEASED
  HOLD
  DOWNGRADED
}

// ---------------------------------------------------------------------------
// Orders + money
// ---------------------------------------------------------------------------

model Order {
  id                 String      @id @default(uuid())
  orderNo            String      @unique
  buyerId            String
  subTotal           Decimal
  feeAmount          Decimal     @default(0)
  vatFeeAmount       Decimal     @default(0)
  totalAmount        Decimal
  transferAmount     Decimal?
  refundIntentAmount Decimal     @default(0) // P4: running sum of approved REDUCE refund intent (P5 pays)
  status             OrderStatus @default(WAITING_PAYMENT)
  shippingAddress    String
  trackingNumber     String?
  deliveryDate       DateTime? // agreed delivery date; reschedule approve mutates it
  paymentExpiredAt   DateTime?
  paidAt             DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  buyer   User        @relation(fields: [buyerId], references: [id])
  items   OrderItem[]
  payment Payment?

  callbackLogs PaymentCallbackLog[]

  // Phase 4: fulfillment
  reschedules      DeliveryReschedule[]
  adjustments      OrderAdjustment[]
  increasePayments IncreasePayment[]
  delivery         Delivery?
  reviews          Review[]
}

// Fruit order lifecycle.
enum OrderStatus {
  WAITING_PAYMENT
  PAID
  PREPARING
  DELIVERED
  CANCELLED
  EXPIRED
  RESCHEDULED
}

model OrderItem {
  id       String  @id @default(uuid())
  orderId  String
  lotId    String
  quantity Int
  price    Decimal

  order Order @relation(fields: [orderId], references: [id])
  lot   Lot   @relation(fields: [lotId], references: [id])

  adjustments OrderAdjustment[]
}

// Per-prefix running counter. Incremented under SELECT ... FOR UPDATE inside a
// transaction to guarantee gap-free, collision-free order numbers (bug #2).
model OrderRunningNo {
  prefix     String   @id
  yymmdd     String
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model Payment {
  id           String        @id @default(uuid())
  orderId      String        @unique
  amount       Decimal
  currency     String        @default("THB")
  status       PaymentStatus @default(PENDING)
  escrowStatus EscrowStatus  @default(HELD)
  channel      String?
  providerRef  String?
  callbackRef  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

// Raw PSP callback audit log. FK to Order (bug #11: real FK, not loose string id).
model PaymentCallbackLog {
  id         String   @id @default(uuid())
  orderId    String?
  invoiceNo  String
  amount     Decimal
  respCode   String
  respDesc   String?
  tranRef    String?
  signature  String?
  rawPayload String
  accepted   Boolean  @default(false)
  receivedAt DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  orchardId String?
  orderId   String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  orchard Orchard? @relation(fields: [orchardId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])

  @@index([orchardId])
  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Admin RBAC (minimal)
// ---------------------------------------------------------------------------

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  roleId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role AdminRole @relation(fields: [roleId], references: [id])

  qcAudits     QcAudit[]
  orchardScope UserOrchardScope[]
}

model AdminRole {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users       AdminUser[]
  permissions AdminRolePermission[]
}

model Permission {
  id   String @id @default(uuid())
  code String @unique // e.g. "orders.read"
  name String

  roles AdminRolePermission[]
}

model AdminRolePermission {
  roleId       String
  permissionId String

  role       AdminRole  @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// ---------------------------------------------------------------------------
// QC / consent / scope
// ---------------------------------------------------------------------------

model QcAudit {
  id          String   @id @default(uuid())
  lotId       String
  fromStatus  QcStatus
  toStatus    QcStatus
  action      String // "RELEASE" | "HOLD" | "DOWNGRADE"
  note        String?
  adminUserId String
  createdAt   DateTime @default(now())

  lot       Lot       @relation(fields: [lotId], references: [id])
  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([lotId])
}

model ConsentLog {
  id         String   @id @default(uuid())
  lineUserId String
  purpose    String
  granted    Boolean
  createdAt  DateTime @default(now())

  @@index([lineUserId])
}

model UserOrchardScope {
  adminUserId String
  orchardId   String

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  orchard   Orchard   @relation(fields: [orchardId], references: [id])

  @@id([adminUserId, orchardId])
}

// ---------------------------------------------------------------------------
// Phase 3: LINE staff binding + messaging
// ---------------------------------------------------------------------------

// LINE staff binding (bug #10: FK to Orchard, not varchar).
model OrchardRegisterCode {
  id         String    @id @default(uuid())
  code       String    @unique
  orchardId  String
  redeemedAt DateTime?
  redeemedBy String? // lineUserId that redeemed
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  orchard Orchard @relation(fields: [orchardId], references: [id])

  @@index([orchardId])
}

// Which LINE staff belong to which orchard (bug #4: detect "no binding").
model OrchardLineBinding {
  id         String   @id @default(uuid())
  orchardId  String
  lineUserId String
  createdAt  DateTime @default(now())

  orchard Orchard @relation(fields: [orchardId], references: [id])

  @@unique([orchardId, lineUserId])
  @@index([lineUserId])
}

// Audit LIFF requests (roadmap §3.5 liff_request_logs).
model LiffRequestLog {
  id         String   @id @default(uuid())
  lineUserId String?
  path       String
  method     String
  status     Int
  createdAt  DateTime @default(now())

  @@index([lineUserId])
  @@index([createdAt])
}

// Bot interaction log (roadmap §3.5 line_bot_logs); bug #6: state lives in DB, not memory.
model LineBotLog {
  id         String   @id @default(uuid())
  lineUserId String?
  eventType  String // "message" | "follow" | "postback" | "unfollow" | ...
  replyToken String?
  text       String?
  rawEvent   String // JSON
  handled    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([lineUserId])
}

// Push queue (bug #5 fix: push is NOT fire-and-forget).
model PushJob {
  id            String     @id @default(uuid())
  event         String
  lineUserId    String
  message       String
  status        PushStatus @default(PENDING)
  attempts      Int        @default(0)
  maxAttempts   Int        @default(3)
  lastError     String?
  nextAttemptAt DateTime   @default(now())
  sentAt        DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status, nextAttemptAt])
  @@index([lineUserId])
}

enum PushStatus {
  PENDING
  SENT
  FAILED
}

// ---------------------------------------------------------------------------
// Phase 4: fulfillment (reschedule / adjustment / increase-pay / delivery / review)
// ---------------------------------------------------------------------------

enum RescheduleStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdjustmentKind {
  REDUCE
  INCREASE
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum IncreasePayStatus {
  PENDING
  SUCCEEDED
  EXPIRED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
}

enum ProposedBy {
  ORCHARD
  BUYER
}

// Orchard proposes / buyer confirms (or vice-versa). Approve mutates Order.deliveryDate.
model DeliveryReschedule {
  id           String           @id @default(uuid())
  orderId      String
  proposedDate DateTime
  proposedBy   ProposedBy
  status       RescheduleStatus @default(PENDING)
  note         String?
  decidedBy    String? // adminUserId OR lineUserId of decider
  decidedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

// Item-grain qty change. REDUCE -> refund intent; INCREASE -> pay-more (IncreasePayment).
model OrderAdjustment {
  id          String           @id @default(uuid())
  orderId     String
  orderItemId String
  kind        AdjustmentKind
  deltaQty    Int // >0 always; direction in `kind`
  amount      Decimal // deltaQty * item.price (refund intent for REDUCE / pay-more for INCREASE)
  status      AdjustmentStatus @default(PENDING)
  note        String?
  proposedBy  ProposedBy
  decidedBy   String?
  decidedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  order           Order            @relation(fields: [orderId], references: [id])
  orderItem       OrderItem        @relation(fields: [orderItemId], references: [id])
  increasePayment IncreasePayment?

  @@index([orderId])
  @@index([orderItemId])
  @@index([status])
}

// Pay-more on qty INCREASE; mock PSP only (Gate 0). 1:1 with the INCREASE adjustment.
model IncreasePayment {
  id           String            @id @default(uuid())
  adjustmentId String            @unique
  orderId      String
  amount       Decimal
  status       IncreasePayStatus @default(PENDING)
  pspRef       String?
  expiresAt    DateTime? // created + HOLD_MS (1h)
  paidAt       DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  adjustment OrderAdjustment @relation(fields: [adjustmentId], references: [id])
  order      Order           @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

// Delivery proof. DeliveryImage stores URL/path only, never binary (bug #7).
model Delivery {
  id              String         @id @default(uuid())
  orderId         String         @unique
  status          DeliveryStatus @default(PENDING)
  trackingNo      String?
  carrier         String?
  proofUploadedBy String? // adminUserId (ops/CX)
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order  Order           @relation(fields: [orderId], references: [id])
  images DeliveryImage[]
}

model DeliveryImage {
  id         String   @id @default(uuid())
  deliveryId String
  url        String // path or URL ONLY, never binary (bug #7)
  uploadedAt DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id])

  @@index([deliveryId])
}
