generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Identity / buyer
// ---------------------------------------------------------------------------

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  role       Role     @default(BUYER)
  lineUserId String?  @unique
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orchards Orchard[]
  orders   Order[]
  reviews  Review[]

  // Phase 6: claims filed by this buyer
  claims Claim[]
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

// LINE user who has passed phone OTP verification. Gate for order creation.
model VerifiedLineUser {
  id         String   @id @default(uuid())
  lineUserId String   @unique
  phone      String
  name       String?
  consent    Boolean  @default(false)
  verifiedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// OTP issuance/verification log. `reference` is the echo token returned to the client.
model OtpLog {
  reference  String    @id
  phone      String
  otp        String
  lineUserId String?
  expiresAt  DateTime
  consumedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone])
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Orchard {
  id          String   @id @default(uuid())
  name        String
  description String?
  province    String
  ownerId     String
  isVerified  Boolean  @default(false)
  rating      Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User  @relation(fields: [ownerId], references: [id])
  lots  Lot[]

  scopes UserOrchardScope[]

  registerCodes OrchardRegisterCode[]
  lineBindings  OrchardLineBinding[]

  reviews Review[]

  // Phase 5: settlement
  payoutAccounts PayoutAccount[]
}

model Lot {
  id              String    @id @default(uuid())
  orchardId       String
  fruitName       String
  variety         String?
  grade           String?
  price           Decimal
  quantity        Int
  unit            String    @default("kg")
  minOrderQty     Int?
  harvestDate     DateTime?
  saleWindowStart DateTime?
  saleWindowEnd   DateTime?
  status          LotStatus @default(DRAFT)
  qcStatus        QcStatus  @default(PENDING)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orchard    Orchard     @relation(fields: [orchardId], references: [id])
  orderItems OrderItem[]
  qcAudits   QcAudit[]
}

enum LotStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  CANCELLED
}

enum QcStatus {
  PENDING
  RELEASED
  HOLD
  DOWNGRADED
}

// ---------------------------------------------------------------------------
// Orders + money
// ---------------------------------------------------------------------------

model Order {
  id                 String      @id @default(uuid())
  orderNo            String      @unique
  buyerId            String
  subTotal           Decimal
  feeAmount          Decimal     @default(0)
  vatFeeAmount       Decimal     @default(0)
  totalAmount        Decimal
  transferAmount     Decimal?
  refundIntentAmount Decimal     @default(0) // P4: running sum of approved REDUCE refund intent (P5 pays)
  refundedAmount     Decimal     @default(0) // P5: running sum of SUCCEEDED refunds (distinct from intent)
  source             OrderSource @default(LIFF) // P5: which surface created the order
  status             OrderStatus @default(WAITING_PAYMENT)
  shippingAddress    String
  trackingNumber     String?
  deliveryDate       DateTime? // agreed delivery date; reschedule approve mutates it
  paymentExpiredAt   DateTime?
  paidAt             DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  buyer   User        @relation(fields: [buyerId], references: [id])
  items   OrderItem[]
  payment Payment?

  callbackLogs PaymentCallbackLog[]

  // Phase 4: fulfillment
  reschedules      DeliveryReschedule[]
  adjustments      OrderAdjustment[]
  increasePayments IncreasePayment[]
  delivery         Delivery?
  reviews          Review[]

  // Phase 5: settlement
  refunds           Refund[]
  payoutBatchOrders PayoutBatchOrder[]

  // Phase 6: ops consoles
  packingManifest PackingManifest?
  claims          Claim[]
}

enum OrderSource {
  LIFF
  SHOP
}

// Fruit order lifecycle.
enum OrderStatus {
  WAITING_PAYMENT
  PAID
  PREPARING
  DELIVERED
  CANCELLED
  EXPIRED
  RESCHEDULED
}

model OrderItem {
  id       String  @id @default(uuid())
  orderId  String
  lotId    String
  quantity Int
  price    Decimal

  order Order @relation(fields: [orderId], references: [id])
  lot   Lot   @relation(fields: [lotId], references: [id])

  adjustments OrderAdjustment[]

  // Phase 6: packing
  packingItems PackingItem[]
}

// Per-prefix running counter. Incremented under SELECT ... FOR UPDATE inside a
// transaction to guarantee gap-free, collision-free order numbers (bug #2).
model OrderRunningNo {
  prefix     String   @id
  yymmdd     String
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model Payment {
  id           String        @id @default(uuid())
  orderId      String        @unique
  amount       Decimal
  currency     String        @default("THB")
  status       PaymentStatus @default(PENDING)
  escrowStatus EscrowStatus  @default(HELD)
  channel      String?
  providerRef  String?
  callbackRef  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

// Raw PSP callback audit log. FK to Order (bug #11: real FK, not loose string id).
model PaymentCallbackLog {
  id         String   @id @default(uuid())
  orderId    String?
  invoiceNo  String
  amount     Decimal
  respCode   String
  respDesc   String?
  tranRef    String?
  signature  String?
  rawPayload String
  accepted   Boolean  @default(false)
  receivedAt DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  orchardId String?
  orderId   String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  orchard Orchard? @relation(fields: [orchardId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])

  @@index([orchardId])
  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Admin RBAC (minimal)
// ---------------------------------------------------------------------------

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  roleId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role AdminRole @relation(fields: [roleId], references: [id])

  qcAudits     QcAudit[]
  orchardScope UserOrchardScope[]

  // Phase 5: settlement audit (createdBy / approvedBy)
  payoutBatches   PayoutBatch[]
  refundsApproved Refund[]
}

model AdminRole {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users       AdminUser[]
  permissions AdminRolePermission[]
}

model Permission {
  id   String @id @default(uuid())
  code String @unique // e.g. "orders.read"
  name String

  roles AdminRolePermission[]
}

model AdminRolePermission {
  roleId       String
  permissionId String

  role       AdminRole  @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// ---------------------------------------------------------------------------
// QC / consent / scope
// ---------------------------------------------------------------------------

model QcAudit {
  id          String   @id @default(uuid())
  lotId       String
  fromStatus  QcStatus
  toStatus    QcStatus
  action      String // "RELEASE" | "HOLD" | "DOWNGRADE"
  note        String?
  adminUserId String
  createdAt   DateTime @default(now())

  lot       Lot       @relation(fields: [lotId], references: [id])
  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([lotId])
}

model ConsentLog {
  id         String   @id @default(uuid())
  lineUserId String
  purpose    String
  granted    Boolean
  createdAt  DateTime @default(now())

  @@index([lineUserId])
}

model UserOrchardScope {
  adminUserId String
  orchardId   String

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  orchard   Orchard   @relation(fields: [orchardId], references: [id])

  @@id([adminUserId, orchardId])
}

// ---------------------------------------------------------------------------
// Phase 3: LINE staff binding + messaging
// ---------------------------------------------------------------------------

// LINE staff binding (bug #10: FK to Orchard, not varchar).
model OrchardRegisterCode {
  id         String    @id @default(uuid())
  code       String    @unique
  orchardId  String
  redeemedAt DateTime?
  redeemedBy String? // lineUserId that redeemed
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  orchard Orchard @relation(fields: [orchardId], references: [id])

  @@index([orchardId])
}

// Which LINE staff belong to which orchard (bug #4: detect "no binding").
model OrchardLineBinding {
  id         String   @id @default(uuid())
  orchardId  String
  lineUserId String
  createdAt  DateTime @default(now())

  orchard Orchard @relation(fields: [orchardId], references: [id])

  @@unique([orchardId, lineUserId])
  @@index([lineUserId])
}

// Audit LIFF requests (roadmap §3.5 liff_request_logs).
model LiffRequestLog {
  id         String   @id @default(uuid())
  lineUserId String?
  path       String
  method     String
  status     Int
  createdAt  DateTime @default(now())

  @@index([lineUserId])
  @@index([createdAt])
}

// Bot interaction log (roadmap §3.5 line_bot_logs); bug #6: state lives in DB, not memory.
model LineBotLog {
  id         String   @id @default(uuid())
  lineUserId String?
  eventType  String // "message" | "follow" | "postback" | "unfollow" | ...
  replyToken String?
  text       String?
  rawEvent   String // JSON
  handled    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([lineUserId])
}

// Push queue (bug #5 fix: push is NOT fire-and-forget).
model PushJob {
  id            String     @id @default(uuid())
  event         String
  lineUserId    String
  message       String
  status        PushStatus @default(PENDING)
  attempts      Int        @default(0)
  maxAttempts   Int        @default(3)
  lastError     String?
  nextAttemptAt DateTime   @default(now())
  sentAt        DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status, nextAttemptAt])
  @@index([lineUserId])
}

enum PushStatus {
  PENDING
  SENT
  FAILED
}

// ---------------------------------------------------------------------------
// Phase 4: fulfillment (reschedule / adjustment / increase-pay / delivery / review)
// ---------------------------------------------------------------------------

enum RescheduleStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdjustmentKind {
  REDUCE
  INCREASE
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum IncreasePayStatus {
  PENDING
  SUCCEEDED
  EXPIRED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
}

enum ProposedBy {
  ORCHARD
  BUYER
}

// Orchard proposes / buyer confirms (or vice-versa). Approve mutates Order.deliveryDate.
model DeliveryReschedule {
  id           String           @id @default(uuid())
  orderId      String
  proposedDate DateTime
  proposedBy   ProposedBy
  status       RescheduleStatus @default(PENDING)
  note         String?
  decidedBy    String? // adminUserId OR lineUserId of decider
  decidedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

// Item-grain qty change. REDUCE -> refund intent; INCREASE -> pay-more (IncreasePayment).
model OrderAdjustment {
  id          String           @id @default(uuid())
  orderId     String
  orderItemId String
  kind        AdjustmentKind
  deltaQty    Int // >0 always; direction in `kind`
  amount      Decimal // deltaQty * item.price (refund intent for REDUCE / pay-more for INCREASE)
  status      AdjustmentStatus @default(PENDING)
  note        String?
  proposedBy  ProposedBy
  decidedBy   String?
  decidedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  order           Order            @relation(fields: [orderId], references: [id])
  orderItem       OrderItem        @relation(fields: [orderItemId], references: [id])
  increasePayment IncreasePayment?
  refund          Refund? // P5: a REDUCE adjustment's intent converts to one Refund

  @@index([orderId])
  @@index([orderItemId])
  @@index([status])
}

// Pay-more on qty INCREASE; mock PSP only (Gate 0). 1:1 with the INCREASE adjustment.
model IncreasePayment {
  id           String            @id @default(uuid())
  adjustmentId String            @unique
  orderId      String
  amount       Decimal
  status       IncreasePayStatus @default(PENDING)
  pspRef       String?
  expiresAt    DateTime? // created + HOLD_MS (1h)
  paidAt       DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  adjustment OrderAdjustment @relation(fields: [adjustmentId], references: [id])
  order      Order           @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

// Delivery proof. DeliveryImage stores URL/path only, never binary (bug #7).
model Delivery {
  id              String         @id @default(uuid())
  orderId         String         @unique
  status          DeliveryStatus @default(PENDING)
  trackingNo      String?
  carrier         String?
  proofUploadedBy String? // adminUserId (ops/CX)
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order  Order           @relation(fields: [orderId], references: [id])
  images DeliveryImage[]
}

model DeliveryImage {
  id         String   @id @default(uuid())
  deliveryId String
  url        String // path or URL ONLY, never binary (bug #7)
  uploadedAt DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id])

  @@index([deliveryId])
}

// ---------------------------------------------------------------------------
// Phase 5: settlement (payout + refund) — mock PSP only (Gate 0); human-only.
// ---------------------------------------------------------------------------

// Seeded BOT bank reference (roadmap §3.3).
model Bank {
  id       String  @id @default(uuid())
  code     String  @unique // BOT bank code e.g. "014" SCB
  name     String
  isActive Boolean @default(true)

  payoutAccounts PayoutAccount[]
}

// Orchard payout destination (§3.4). bug #11: real FKs.
model PayoutAccount {
  id        String   @id @default(uuid())
  orchardId String
  bankId    String
  accNo     String
  accName   String
  payoutKey String? // PSP beneficiary key (mock)
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orchard           Orchard            @relation(fields: [orchardId], references: [id])
  bank              Bank               @relation(fields: [bankId], references: [id])
  payoutBatchOrders PayoutBatchOrder[]

  @@index([orchardId])
}

// Take-rate config (§5 #9). Single active row; env is bootstrap fallback.
model PlatformConfig {
  id        String   @id @default(uuid())
  takeRate  Decimal  @default("0.10") // 0.10 / 0.125 / 0.15
  vatRate   Decimal  @default("0.07")
  isActive  Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  @@index([isActive])
}

// Human-created payout batch (§3.4 payout_transactions).
model PayoutBatch {
  id          String            @id @default(uuid())
  batchNo     String            @unique // order-no scheme, prefix "PB"
  status      PayoutBatchStatus @default(DRAFT)
  totalAmount Decimal           @default(0)
  pspBatchRef String?
  createdBy   String // AdminUser.id (human-only)
  submittedAt DateTime?
  settledAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  createdByAdmin AdminUser          @relation(fields: [createdBy], references: [id])
  orders         PayoutBatchOrder[]
  responses      PayoutResponse[]
  errorLogs      PayoutErrorLog[]

  @@index([status])
}

enum PayoutBatchStatus {
  DRAFT
  SUBMITTED
  SUCCEEDED
  FAILED
}

// Order line within a payout batch (§3.4 payout_transaction_orders).
model PayoutBatchOrder {
  id              String  @id @default(uuid())
  payoutBatchId   String
  orderId         String
  payoutAccountId String
  amount          Decimal // = order.transferAmount snapshot at batch time

  batch         PayoutBatch   @relation(fields: [payoutBatchId], references: [id])
  order         Order         @relation(fields: [orderId], references: [id])
  payoutAccount PayoutAccount @relation(fields: [payoutAccountId], references: [id])

  @@unique([payoutBatchId, orderId]) // one order per batch (dedup)
  @@index([orderId])
}

// Raw payout callback audit (§3.4 payout_responses). bug #11: real FK to batch.
model PayoutResponse {
  id            String   @id @default(uuid())
  payoutBatchId String
  respCode      String
  respDesc      String?
  pspBatchRef   String?
  signature     String?
  rawPayload    String
  accepted      Boolean  @default(false)
  receivedAt    DateTime @default(now())

  batch PayoutBatch @relation(fields: [payoutBatchId], references: [id])

  @@index([payoutBatchId])
}

// Payout error audit (§3.4 payout_error_logs). bug #11: real FK to batch.
model PayoutErrorLog {
  id            String   @id @default(uuid())
  payoutBatchId String
  errorCode     String?
  errorMessage  String
  rawPayload    String?
  createdAt     DateTime @default(now())

  batch PayoutBatch @relation(fields: [payoutBatchId], references: [id])

  @@index([payoutBatchId])
}

// Refund (§3.4 saleorder_refunds). Converts a P4 REDUCE intent or a full-order cancel.
model Refund {
  id                String       @id @default(uuid())
  refundNo          String       @unique // order-no scheme, prefix "RF"
  orderId           String
  orderAdjustmentId String?      @unique // 1:1 with the REDUCE adjustment when item-grain
  claimId           String?      @unique // P6: 1:1 with the Claim when a claim resolution refunds
  amount            Decimal
  kind              RefundKind // FULL | PARTIAL
  payoutType        RefundPayout @default(CUSTOMER) // CUSTOMER (refund buyer) | PLANT (clawback orchard)
  status            RefundStatus @default(PENDING)
  pspRef            String? // "RF-..." invoice for callback correlation (mock)
  approvedBy        String // AdminUser.id (human-only)
  approvedAt        DateTime?
  settledAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  order           Order            @relation(fields: [orderId], references: [id])
  orderAdjustment OrderAdjustment? @relation(fields: [orderAdjustmentId], references: [id])
  approvedByAdmin AdminUser        @relation(fields: [approvedBy], references: [id])
  claim           Claim?           @relation(fields: [claimId], references: [id])

  @@index([orderId])
  @@index([status])
}

enum RefundKind {
  FULL
  PARTIAL
}

enum RefundPayout {
  CUSTOMER
  PLANT
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Phase 6: ops consoles — packing/manifest reconcile (Flow 6) + claim intake/triage (Flow 7).
// Both human-gated; AI may classify/flag only, never sign off / transition. Images URL-only.
// ---------------------------------------------------------------------------

// Count/label reconcile before logistics handoff. One manifest per Order (1:1).
// expectedQty seeds from OrderItem.quantity; ops enters packedQty; variance flagged;
// human sign-off required (cannot sign off from OPEN; VARIANCE sign-off needs a note).
model PackingManifest {
  id           String        @id @default(uuid())
  orderId      String        @unique
  status       PackingStatus @default(OPEN)
  expectedCount Int          @default(0) // sum(expectedQty)
  packedCount  Int           @default(0) // sum(packedQty)
  hasVariance  Boolean       @default(false)
  note         String? // human override note (required to sign off a VARIANCE manifest)
  packedBy     String? // AdminUser.id who last reconciled
  packedAt     DateTime?
  signedOffBy  String? // AdminUser.id who signed off (human-only)
  signedOffAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  order  Order           @relation(fields: [orderId], references: [id])
  items  PackingItem[]
  images ManifestImage[]

  @@index([status])
}

enum PackingStatus {
  OPEN
  RECONCILED
  VARIANCE
  SIGNED_OFF
}

// Per-OrderItem packing line. expectedQty from OrderItem.quantity; packedQty entered by ops.
model PackingItem {
  id          String   @id @default(uuid())
  manifestId  String
  orderItemId String
  expectedQty Int
  packedQty   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manifest  PackingManifest @relation(fields: [manifestId], references: [id])
  orderItem OrderItem       @relation(fields: [orderItemId], references: [id])

  @@unique([manifestId, orderItemId])
  @@index([manifestId])
}

// Manifest evidence image. URL/path ONLY, never binary (bug #7).
model ManifestImage {
  id         String   @id @default(uuid())
  manifestId String
  url        String
  uploadedAt DateTime @default(now())

  manifest PackingManifest @relation(fields: [manifestId], references: [id])

  @@index([manifestId])
}

// Buyer files a claim with evidence -> AI/ops classify+flag (allowed) -> human triage/resolve.
// State machine in lib/claim.ts; transitions (except buyer-file OPEN) require claims.write.
model Claim {
  id          String        @id @default(uuid())
  claimNo     String        @unique // order-no scheme, prefix "CL"
  orderId     String
  buyerId     String? // shop buyer User (phone path)
  lineUserId  String? // LIFF buyer (LINE path)
  category    ClaimCategory @default(OTHER)
  severity    ClaimSeverity @default(LOW)
  description String
  status      ClaimStatus   @default(OPEN)
  aiFlag      String? // AI/ops suggestion only (never transitions)
  resolvedBy  String? // AdminUser.id (human-only)
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order  Order        @relation(fields: [orderId], references: [id])
  buyer  User?        @relation(fields: [buyerId], references: [id])
  images ClaimImage[]
  events ClaimEvent[]
  refund Refund? // P6: 1:1 with the refund created on RESOLVED + createRefund

  @@index([orderId])
  @@index([status])
}

enum ClaimCategory {
  DAMAGED
  QUALITY
  MISSING
  OTHER
}

enum ClaimSeverity {
  LOW
  MEDIUM
  HIGH
}

enum ClaimStatus {
  OPEN
  TRIAGING
  RESOLVED
  REJECTED
  ESCALATED
}

// Claim evidence image. URL/path ONLY, never binary (bug #7).
model ClaimImage {
  id         String   @id @default(uuid())
  claimId    String
  url        String
  uploadedAt DateTime @default(now())

  claim Claim @relation(fields: [claimId], references: [id])

  @@index([claimId])
}

// ---------------------------------------------------------------------------
// Phase 7: scheduled jobs (cron dedup) + reconciliation audit snapshots.
// ---------------------------------------------------------------------------

// Once-per-period cron dedup (roadmap §3.5 cron_logs; atomic claim on task+period).
// First caller create()s the row; a duplicate fire hits @@unique -> P2002 -> skip.
model CronLog {
  id     String   @id @default(uuid())
  task   String // "expiry-sweep" | "reminder" | "push-sweep"
  period String // "2026-06-27" (daily) | "2026-06-27T14" (hourly) | "2026-06-27T1405" (5-min slot)
  status String   @default("RUNNING") // RUNNING | DONE | FAILED
  note   String? // JSON summary (counts, ids)
  runAt  DateTime @default(now())

  @@unique([task, period])
  @@index([task, runAt])
}

// Optional daily/monthly reconcile audit snapshot. Reconcile is computed live; this only
// freezes a result + variance for history. Never on the hot path. createdBy kept a soft
// String (AdminUser.id audit ref) to avoid a back-relation on AdminUser.
model ReconciliationSnapshot {
  id          String   @id @default(uuid())
  period      String   @unique // "2026-06-27" or "2026-06"
  paymentsIn  Decimal  @default(0)
  payoutsOut  Decimal  @default(0)
  refundsOut  Decimal  @default(0)
  platformFee Decimal  @default(0)
  heldEscrow  Decimal  @default(0)
  variance    Decimal  @default(0)
  note        String?
  createdBy   String // AdminUser.id
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// Append-only audit of every claim transition (written in the same tx as the transition).
model ClaimEvent {
  id         String       @id @default(uuid())
  claimId    String
  action     String // "FILE" | "TRIAGE" | "CLASSIFY" | "RESOLVE" | "REJECT" | "ESCALATE"
  fromStatus ClaimStatus?
  toStatus   ClaimStatus
  actor      String // AdminUser.id, lineUserId, or buyer phone (file)
  note       String?
  createdAt  DateTime     @default(now())

  claim Claim @relation(fields: [claimId], references: [id])

  @@index([claimId])
}
